{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RedisME",
  "version": "0.1.3",
  "identifier": "com.hepengju.redis",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RedisME",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "nsis",
      "dmg"
    ],
    "icon": [
      "resources/icons/128x128.png",
      "resources/icons/128x128@2x.png",
      "resources/icons/512x512.png",
      "resources/icons/icon.ico",
      "resources/icons/icon.icns",
      "resources/icons/icon.png",
      "resources/icons/icon.svg"
    ],
    "resources": [
      "resources/conf/*"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "language": [
          "en-US",
          "zh-CN"
        ]
      },
      "nsis": {
        "languages": [
          "English",
          "SimpChinese"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEOUEwQjM0QkRCRjUxQjQKUldTMFViKzlOQXVhL2NZVEpaWlVqazNQNkVFaytuOUZnUmFWa2FBbE1tWFgyYWZWajd6cDlKMk4K",
      "endpoints": [
        "https://github.com/hepengju/redis-me/releases/latest/download/latest.json"
      ]
    }
  }
}
